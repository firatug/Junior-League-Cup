<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — JLC Admin</title>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body class="admin-body">
    <header class="admin-header">
        <div class="admin-header-inner">
            <a asp-controller="Admin" asp-action="Index" class="admin-brand">JLC Admin</a>
            @if (User.Identity?.IsAuthenticated == true)
            {
                <div class="admin-header-actions">
                    <span class="admin-user">@User.Identity.Name</span>
                    <form asp-controller="Admin" asp-action="Logout" method="post" style="display:inline;">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-outline-dark btn-sm">Çıkış</button>
                    </form>
                </div>
            }
        </div>
    </header>
    <main class="admin-main">
        @RenderBody()
    </main>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
