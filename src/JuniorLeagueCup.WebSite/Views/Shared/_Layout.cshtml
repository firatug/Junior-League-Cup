<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="@(ViewData["Description"] ?? "Junior League Cup — Türkiye genelinde 7-8 yaş futbol takımları için bölgesel seçmeler ve Antalya final organizasyonu. Road to Antalya.")" />
    <meta property="og:title" content="@(ViewData["Title"] ?? "Ana Sayfa") | Junior League Cup" />
    <meta property="og:description" content="@(ViewData["Description"] ?? "Road to Antalya — Geleceğin oyuncuları burada başlar.")" />
    <meta property="og:type" content="website" />
    <title>@(ViewData["Title"] ?? "Ana Sayfa") | Junior League Cup</title>
    <link rel="icon" type="image/png" href="~/images/logo.png" asp-append-version="true" />
    <link rel="apple-touch-icon" href="~/images/logo.png" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <div class="page-loader" id="pageLoader" aria-hidden="true">
        <div class="loader-ball"></div>
    </div>

    <header class="site-header" id="siteHeader">
        <div class="container header-inner">
            <a class="brand" asp-controller="Home" asp-action="Index" aria-label="Junior League Cup — Ana Sayfa">
                <partial name="_BrandLogo" />
            </a>

            <button class="nav-toggle" id="navToggle" type="button" aria-label="Menüyü aç/kapat" aria-expanded="false">
                <span></span><span></span><span></span>
            </button>

            <nav class="main-nav" id="mainNav">
                @{
                    var action = ViewContext.RouteData.Values["action"]?.ToString();
                }
                <a asp-action="Index" class="nav-link @(action == "Index" ? "active" : "")">Ana Sayfa</a>
                <a asp-action="JlcNedir" class="nav-link @(action == "JlcNedir" ? "active" : "")">JLC Nedir?</a>
                <a asp-action="BolgeselSecmeler" class="nav-link @(action == "BolgeselSecmeler" ? "active" : "")">Bölgesel Seçmeler</a>
                <a asp-action="AntalyaFinali" class="nav-link @(action == "AntalyaFinali" ? "active" : "")">Antalya Finali</a>
                <a asp-action="Medya" class="nav-link @(action == "Medya" ? "active" : "")">Medya</a>
                <a asp-action="Hakkimizda" class="nav-link @(action == "Hakkimizda" ? "active" : "")">Hakkımızda</a>
                <div class="nav-actions">
                    <a asp-action="TakimBasvurusu" class="btn btn-primary btn-sm nav-cta">Takım Başvurusu</a>
                    <a asp-action="CanliSkor" class="live-link @(action == "CanliSkor" ? "active" : "")" aria-label="Canlı skor ve fikstür">
                        <span class="live-dot" aria-hidden="true"></span>
                        LIVE
                    </a>
                </div>
            </nav>
        </div>
    </header>

    <main>
        @RenderBody()
    </main>

    <footer class="site-footer">
        <div class="footer-top">
            <div class="container footer-grid">
                <div class="footer-brand-col">
                    <a class="brand brand--footer" asp-controller="Home" asp-action="Index" aria-label="Junior League Cup — Ana Sayfa">
                        <partial name="_BrandLogo" view-data="@(new ViewDataDictionary(ViewData) { { "BrandContext", "footer" } })" />
                    </a>
                    <p class="footer-zenit">Zenit Event — Zenit Turizm</p>
                    <p>Türkiye'nin genç futbol yetenekleri için bölgesel seçmelerden Antalya finaline uzanan profesyonel organizasyon markası.</p>
                    <div class="social-links">
                        <a href="#" aria-label="Instagram">IG</a>
                        <a href="#" aria-label="Facebook">FB</a>
                        <a href="#" aria-label="YouTube">YT</a>
                        <a href="#" aria-label="LinkedIn">IN</a>
                    </div>
                </div>
                <div>
                    <h4>Organizasyon</h4>
                    <ul class="footer-links">
                        <li><a asp-action="JlcNedir">JLC Nedir?</a></li>
                        <li><a asp-action="BolgeselSecmeler">Bölgesel Seçmeler</a></li>
                        <li><a asp-action="AntalyaFinali">Antalya Finali</a></li>
                        <li><a asp-action="ProgramFikstur">Program / Fikstür</a></li>
                        <li><a asp-action="Takimlar">Takımlar</a></li>
                    </ul>
                </div>
                <div>
                    <h4>Katılım</h4>
                    <ul class="footer-links">
                        <li><a asp-action="TakimBasvurusu">Takım Başvurusu</a></li>
                        <li><a asp-action="VeliOyuncuDeneyimi">Veli & Oyuncu Deneyimi</a></li>
                        <li><a asp-action="ScoutSistemi">Scout Sistemi</a></li>
                        <li><a asp-action="Sponsorluk">Sponsorluk</a></li>
                        <li><a asp-action="Oteller">Otel & Konaklama</a></li>
                    </ul>
                </div>
                <div>
                    <h4>İletişim</h4>
                    <ul class="footer-contact">
                        <li>Antalya & İstanbul, Türkiye</li>
                        <li>info@juniorleaguecup.com</li>
                        <li><a asp-action="Iletisim">İletişim Formu</a></li>
                    </ul>
                </div>
            </div>
        </div>
        <div class="footer-bottom">
            <div class="container footer-bottom-inner">
                <span>&copy; @DateTime.Now.Year Junior League Cup — Zenit Event. Tüm hakları saklıdır.</span>
                <div class="footer-legal">
                    <a asp-action="Kvkk">KVKK</a>
                    <a asp-action="CerezPolitikasi">Çerez Politikası</a>
                    <a asp-action="KullanimSartlari">Kullanım Şartları</a>
                </div>
            </div>
        </div>
    </footer>

    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
