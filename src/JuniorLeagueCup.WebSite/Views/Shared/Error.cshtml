@model ErrorViewModel
@{
    ViewData["Title"] = "Hata";
}

<section class="page-hero">
    <div class="container" style="text-align: center;">
        <h1>BİR HATA OLUŞTU</h1>
        <p style="color: var(--gray-300); margin-top: 1rem;">İsteğiniz işlenirken beklenmeyen bir sorun oluştu.</p>
        @if (Model.ShowRequestId)
        {
            <p style="margin-top: 1rem; font-size: 0.9rem; color: var(--gray-500);">
                İstek Kimliği: <code>@Model.RequestId</code>
            </p>
        }
        <a asp-action="Index" class="btn btn-primary" style="margin-top: 2rem;">Ana Sayfaya Dön</a>
    </div>
</section>
