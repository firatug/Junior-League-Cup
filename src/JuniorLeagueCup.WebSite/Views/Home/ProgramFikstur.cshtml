@{
    ViewData["Title"] = "Program / Fikstür";
    ViewData["Description"] = "Junior League Cup program ve fikstür — bölgesel seçmeler ve Antalya final maç programı.";
}

<section class="page-hero">
    <div class="container">
        <h1>PROGRAM / FİKSTÜR</h1>
        <p class="lead">Bölgesel seçme ve Antalya final programı yakında yayınlanacaktır.</p>
        <p class="breadcrumb"><a asp-action="Index">Ana Sayfa</a> / Program</p>
    </div>
</section>

<section class="content-section">
    <div class="container">
        <div class="placeholder-box">
            <strong>Fikstür Sistemi Hazırlanıyor</strong>
            <p>Bölgesel seçme programı, Antalya final programı, grup maçları, eleme maçları, final maçı ve kupa töreni bu alanda dinamik olarak yönetilecektir.</p>
        </div>
        <div class="features-grid" style="margin-top:2.5rem;">
            <div class="feature-box"><h3>Bölgesel Seçme Programı</h3><p>Şehir bazlı maç takvimi.</p></div>
            <div class="feature-box"><h3>Antalya Final Programı</h3><p>Final organizasyonu fikstürü.</p></div>
            <div class="feature-box"><h3>Maç Sonuçları</h3><p>Canlı skor ve sonuçlar (yakında).</p></div>
        </div>
    </div>
</section>
