@model JuniorLeagueCup.WebSite.Models.IletisimFormModel
@{
    ViewData["Title"] = "Contact";
    ViewData["Description"] = "Contact Junior League Cup — team applications, sponsorship, scout partnerships, and general inquiries.";
}

<section class="page-hero">
    <div class="container">
        <h1>CONTACT</h1>
        <p class="lead">Reach out with your questions and partnership requests.</p>
        <p class="breadcrumb"><a asp-action="Index">Home</a> / Contact</p>
    </div>
</section>

<section class="content-section">
    <div class="container contact-grid">
        <div class="contact-info-card">
            <div class="contact-item">
                <div class="icon" aria-hidden="true">📍</div>
                <div>
                    <strong>Address</strong>
                    <span>Çağlayan Mah. Fener Caddesi No.48 D.1<br />Muratpaşa / Antalya, Turkey</span>
                </div>
            </div>
            <div class="contact-item">
                <div class="icon" aria-hidden="true">📞</div>
                <div><strong>Phone</strong><span><a href="tel:+902423240354">+90 242 324 03 54</a></span></div>
            </div>
            <div class="contact-item">
                <div class="icon" aria-hidden="true">✉️</div>
                <div><strong>Email</strong><span><a href="mailto:info@juniorleaguecup.com">info@juniorleaguecup.com</a></span></div>
            </div>
            <div class="contact-item">
                <div class="icon" aria-hidden="true">🏢</div>
                <div>
                    <strong>Organization</strong>
                    <span>Zenit Event — Junior League Cup<br />ATA Ventures brand</span>
                </div>
            </div>
            <p style="margin-top:1.5rem;font-size:0.9rem;color:var(--text-muted);">
                For team applications, please use the <a asp-action="TakimBasvurusu" style="color:var(--accent);font-weight:600;">application form</a>.
            </p>
        </div>

        <form class="contact-form" asp-action="IletisimPost" method="post">
            <div asp-validation-summary="All" class="admin-alert admin-alert-error" style="margin-bottom:1rem;"></div>
            <div class="form-row">
                <div class="form-group">
                    <label asp-for="FullName">Full Name</label>
                    <input asp-for="FullName" />
                    <span asp-validation-for="FullName" class="admin-field-error"></span>
                </div>
                <div class="form-group">
                    <label asp-for="Phone">Phone</label>
                    <input asp-for="Phone" type="tel" />
                    <span asp-validation-for="Phone" class="admin-field-error"></span>
                </div>
            </div>
            <div class="form-group">
                <label asp-for="Email">Email</label>
                <input asp-for="Email" type="email" />
                <span asp-validation-for="Email" class="admin-field-error"></span>
            </div>
            <div class="form-group">
                <label asp-for="Subject">Subject</label>
                <select asp-for="Subject">
                    <option value="">Select</option>
                    <option>Team Application</option>
                    <option>Sponsorship</option>
                    <option>Scout Partnership</option>
                    <option>Hotel Partnership</option>
                    <option>Media</option>
                    <option>General Inquiry</option>
                </select>
                <span asp-validation-for="Subject" class="admin-field-error"></span>
            </div>
            <div class="form-group">
                <label asp-for="Message">Message</label>
                <textarea asp-for="Message"></textarea>
                <span asp-validation-for="Message" class="admin-field-error"></span>
            </div>
            <div class="form-check">
                <input asp-for="Kvkk" />
                <label asp-for="Kvkk">I have read and accept the <a asp-action="Kvkk" target="_blank">privacy notice (KVKK)</a>.</label>
                <span asp-validation-for="Kvkk" class="admin-field-error"></span>
            </div>
            <div class="form-check">
                <input asp-for="Cerez" />
                <label asp-for="Cerez">I have read and accept the <a asp-action="CerezPolitikasi" target="_blank">cookie policy</a>.</label>
                <span asp-validation-for="Cerez" class="admin-field-error"></span>
            </div>
            <button type="submit" class="btn btn-primary">Send</button>
        </form>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
