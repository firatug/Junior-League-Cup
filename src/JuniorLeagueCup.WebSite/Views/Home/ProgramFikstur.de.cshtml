@{
    ViewData["Title"] = "Spielplan / Termine";
    ViewData["Description"] = "Spielplan und Termine der Junior League Cup — regionale Auswahlen und Antalya-Finale.";
}

<section class="page-hero">
    <div class="container">
        <h1>SPIELPLAN / TERMINE</h1>
        <p class="lead">Die Terminpläne für regionale Auswahlen und das Antalya-Finale werden in Kürze veröffentlicht.</p>
        <p class="breadcrumb"><a asp-action="Index">Startseite</a> / Spielplan</p>
    </div>
</section>

<section class="content-section">
    <div class="container">
        <div class="placeholder-box">
            <strong>Spielplansystem demnächst verfügbar</strong>
            <p>Terminpläne der regionalen Auswahlen, Antalya-Finale-Programm, Gruppenspiele, K.o.-Runden, Finale und Pokalverleihung werden in diesem Bereich dynamisch verwaltet.</p>
        </div>
        <div class="features-grid" style="margin-top:2.5rem;">
            <div class="feature-box"><h3>Terminplan regionale Auswahlen</h3><p>Städtischer Spielkalender.</p></div>
            <div class="feature-box"><h3>Antalya-Finale Terminplan</h3><p>Spielplan des Finale-Events.</p></div>
            <div class="feature-box"><h3>Spielergebnisse</h3><p>Live-Ergebnisse und Resultate (demnächst).</p></div>
        </div>
    </div>
</section>
