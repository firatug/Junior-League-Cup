@{
    ViewData["Title"] = "Hakkımızda";
    ViewData["Description"] = "Junior League Cup hakkında — Zenit Event ve Zenit Turizm çatısı altında yeni nesil çocuk futbol organizasyonu.";
}

<section class="page-hero">
    <div class="container">
        <h1>HAKKIMIZDA</h1>
        <p class="lead">Zenit Event tarafından geliştirilen yeni nesil çocuk futbol organizasyonu.</p>
        <p class="breadcrumb"><a asp-action="Index">Ana Sayfa</a> / Hakkımızda</p>
    </div>
</section>

<section class="content-section">
    <div class="container content-grid">
        <div class="content-image" style="background-image: url('https://images.unsplash.com/photo-1560272564-c83b66b1bd40?w=900&q=80');" role="img" aria-label="Futbol organizasyonu"></div>
        <div class="content-text">
            <span class="section-label">Zenit Event</span>
            <h2>Profesyonel Organizasyon Markası</h2>
            <p>
                Junior League Cup, Zenit Turizm çatısı altında faaliyet gösteren Zenit Event tarafından geliştirilen yeni nesil çocuk futbol organizasyonudur.
                Proje, spor organizasyonu, medya, turizm ve çocuk futbol gelişimini aynı çatı altında birleştirerek sürdürülebilir ve profesyonel bir organizasyon modeli oluşturmayı hedefler.
            </p>
            <ul class="check-list">
                <li>Bölgesel seçmeler ve Antalya finali</li>
                <li>Scout görünürlüğü ve medya gücü</li>
                <li>Sponsorluk ve spor turizmi entegrasyonu</li>
                <li>Uluslararası büyümeye uygun marka yapısı</li>
            </ul>
        </div>
    </div>
</section>

<section class="content-section section-muted">
    <div class="container">
        <div class="cta-banner">
            <div class="cta-bg" aria-hidden="true"></div>
            <div class="cta-overlay" aria-hidden="true"></div>
            <div class="cta-content">
                <h2>ROAD TO ANTALYA</h2>
                <p>Türkiye'nin genç futbol yetenekleri için profesyonel organizasyon yolculuğu.</p>
                <a asp-action="TakimBasvurusu" class="btn btn-gold">Takım Başvurusu</a>
                <a asp-action="Sponsorluk" class="btn btn-outline">Sponsor Ol</a>
            </div>
        </div>
    </div>
</section>
