@model JuniorLeagueCup.WebSite.Models.SponsorlukFormModel
@{
    ViewData["Title"] = "Sponsorluk";
    ViewData["Description"] = "Junior League Cup sponsorluk fırsatları — ana sponsor, bölgesel sponsor, medya ve forma sponsorluğu.";
}

<section class="page-hero">
    <div class="container">
        <h1>SPONSORLUK</h1>
        <p class="lead">Geleceğin futbol hikâyesinde markanıza yer açın.</p>
        <p class="breadcrumb"><a asp-action="Index">Ana Sayfa</a> / Sponsorluk</p>
    </div>
</section>

<section class="content-section">
    <div class="container">
        <p style="max-width:720px;margin:0 auto 2.5rem;text-align:center;color:var(--text-muted);">
            Junior League Cup, çocuk futbolu, aile deneyimi, medya görünürlüğü, spor turizmi ve sosyal etkiyi bir araya getiren güçlü bir sponsorluk platformudur.
        </p>
        <div class="sponsor-grid">
            @foreach (var tier in new[] { "Ana Sponsor", "Bölgesel Sponsor", "Forma Sponsoru", "Saha Sponsoru", "Scout Deneyimi Sponsoru", "Medya Sponsoru", "MVP Ödül Sponsoru", "Aile Etkinlik Sponsoru" })
            {
                <div class="sponsor-tier">
                    <h3>@tier</h3>
                    <ul>
                        <li>Logo görünürlüğü</li>
                        <li>Sosyal medya görünürlüğü</li>
                        <li>Web sitesi görünürlüğü</li>
                        <li>Organizasyon alanı görünürlüğü</li>
                        <li>Haber ve medya içerikleri</li>
                        <li>Özel marka aktivasyonu</li>
                    </ul>
                </div>
            }
        </div>
    </div>
</section>

<section class="content-section section-muted">
    <div class="container">
        <div class="section-header">
            <h2>Sponsorluk Dosyası Talep Et</h2>
        </div>
        <form class="apply-form" asp-action="SponsorlukPost" method="post" style="max-width:720px;margin:0 auto;">
            <div asp-validation-summary="All" class="admin-alert admin-alert-error" style="margin-bottom:1rem;"></div>
            <div class="form-row">
                <div class="form-group">
                    <label asp-for="Company"></label>
                    <input asp-for="Company" />
                    <span asp-validation-for="Company" class="admin-field-error"></span>
                </div>
                <div class="form-group">
                    <label asp-for="Contact"></label>
                    <input asp-for="Contact" />
                    <span asp-validation-for="Contact" class="admin-field-error"></span>
                </div>
            </div>
            <div class="form-row">
                <div class="form-group">
                    <label asp-for="Phone"></label>
                    <input asp-for="Phone" type="tel" />
                    <span asp-validation-for="Phone" class="admin-field-error"></span>
                </div>
                <div class="form-group">
                    <label asp-for="Email"></label>
                    <input asp-for="Email" type="email" />
                    <span asp-validation-for="Email" class="admin-field-error"></span>
                </div>
            </div>
            <div class="form-group">
                <label asp-for="SponsorType"></label>
                <select asp-for="SponsorType">
                    <option>Ana Sponsor</option>
                    <option>Bölgesel Sponsor</option>
                    <option>Forma Sponsoru</option>
                    <option>Medya Sponsoru</option>
                    <option>Diğer</option>
                </select>
            </div>
            <div class="form-group">
                <label asp-for="Message"></label>
                <textarea asp-for="Message" rows="4"></textarea>
            </div>
            <button type="submit" class="btn btn-primary">Talep Gönder</button>
        </form>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
