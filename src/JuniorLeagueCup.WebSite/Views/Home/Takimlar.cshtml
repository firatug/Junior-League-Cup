@{
    ViewData["Title"] = "Takımlar";
    ViewData["Description"] = "Junior League Cup takımları — ön kayıt, bölge şampiyonu ve Antalya finalistleri.";
}

<section class="page-hero">
    <div class="container">
        <h1>TAKIMLAR</h1>
        <p class="lead">Kayıtlı takımlar ve organizasyon durumları.</p>
        <p class="breadcrumb"><a asp-action="Index">Ana Sayfa</a> / Takımlar</p>
    </div>
</section>

<section class="content-section">
    <div class="container">
        <div class="card-grid">
            @foreach (var team in new[] {
                new { Name = "İstanbul Yıldızları", City = "İstanbul", Age = "7-8", Region = "Marmara", Status = "Ön Kayıt", Class = "" },
                new { Name = "Ankara Gençler", City = "Ankara", Age = "7-8", Region = "İç Anadolu", Status = "Ön Kayıt", Class = "" },
                new { Name = "Ege Minikler", City = "İzmir", Age = "7-8", Region = "Ege", Status = "Bölge Şampiyonu", Class = "champion" },
                new { Name = "Akdeniz Yıldız", City = "Antalya", Age = "7-8", Region = "Akdeniz", Status = "Antalya Finalisti", Class = "finalist" },
                new { Name = "Bursa Spor U8", City = "Bursa", Age = "8", Region = "Marmara", Status = "Ön Kayıt", Class = "" },
                new { Name = "Çukurova Minikler", City = "Adana", Age = "7", Region = "Akdeniz", Status = "Ön Kayıt", Class = "" }
            })
            {
                <article class="card team-card">
                    <div class="card-body">
                        <div class="team-logo">@team.Name.Substring(0, 1)</div>
                        <h3>@team.Name</h3>
                        <div class="card-meta">
                            <span>@team.City</span>
                            <span>@team.Age yaş</span>
                            <span>@team.Region</span>
                        </div>
                        <span class="status-badge @team.Class">@team.Status</span>
                    </div>
                </article>
            }
        </div>
        <p style="text-align:center;margin-top:2rem;color:var(--text-muted);">Oyuncu profili altyapısı ileride aktif edilecektir.</p>
    </div>
</section>
