@{
    ViewData["Title"] = "Veli ve Oyuncu Deneyimi";
    ViewData["Description"] = "Junior League Cup veli ve oyuncu deneyim paketleri — profesyonel saha, medya içerikleri ve scout görünürlüğü.";
}

<section class="page-hero">
    <div class="container">
        <h1>VELİ & OYUNCU DENEYİMİ</h1>
        <p class="lead">Çocuğunuz için sadece bir turnuva değil, unutulmaz bir futbol deneyimi.</p>
        <p class="breadcrumb"><a asp-action="Index">Ana Sayfa</a> / Veli & Oyuncu Deneyimi</p>
    </div>
</section>

<section class="content-section">
    <div class="container">
        <div class="features-grid" style="margin-bottom:3rem;">
            <div class="feature-box"><div class="feature-icon">🏟</div><h3>Profesyonel Saha Atmosferi</h3><p>Organizasyon standartlarında maç deneyimi.</p></div>
            <div class="feature-box"><div class="feature-icon">📸</div><h3>Fotoğraf & Video</h3><p>Oyuncu çekimleri ve medya içerikleri.</p></div>
            <div class="feature-box"><div class="feature-icon">🪪</div><h3>Kişisel Oyuncu Kartı</h3><p>Dijital ve basılı oyuncu profili.</p></div>
            <div class="feature-box"><div class="feature-icon">📊</div><h3>Performans Değerlendirme</h3><p>Gelişim odaklı raporlama seçenekleri.</p></div>
            <div class="feature-box"><div class="feature-icon">👁</div><h3>Scout Görünürlüğü</h3><p>Gözlem ve değerlendirme fırsatı.</p></div>
            <div class="feature-box"><div class="feature-icon">🏨</div><h3>Aile Konaklama</h3><p>Antalya'da organizasyon ve etkinlik deneyimi.</p></div>
        </div>
        <div class="package-grid">
            <div class="package-card">
                <h3>Standart Deneyim Paketi</h3>
                <p class="package-desc">Temel organizasyon katılımı.</p>
                <ul>
                    <li>Organizasyon katılımı</li>
                    <li>Maç programı</li>
                    <li>Takım fikstürü</li>
                    <li>Temel medya görünürlüğü</li>
                </ul>
            </div>
            <div class="package-card featured">
                <h3>Premium Oyuncu Paketi</h3>
                <p class="package-desc">Gelişmiş medya ve profil.</p>
                <ul>
                    <li>Profesyonel fotoğraf çekimi</li>
                    <li>Oyuncu kartı</li>
                    <li>Kısa video içerik</li>
                    <li>Performans raporu</li>
                </ul>
            </div>
            <div class="package-card">
                <h3>Elite Scout Paketi</h3>
                <p class="package-desc">Detaylı profil ve scout alanı.</p>
                <ul>
                    <li>Detaylı oyuncu profili</li>
                    <li>Scout değerlendirme raporu</li>
                    <li>Özel medya içeriği</li>
                    <li>Röportaj / tanıtım alanı</li>
                </ul>
            </div>
        </div>
        <p style="text-align:center;margin-top:2rem;color:var(--text-muted);">Fiyatlandırma yönetim panelinden güncellenecektir.</p>
    </div>
</section>
