@{
    ViewData["Title"] = "Scout-System";
    ViewData["Description"] = "Junior League Cup Scout-System — Sichtbarkeits- und Bewertungsmöglichkeiten für junge Talente.";
}

<section class="page-hero">
    <div class="container">
        <h1>SCOUT-SYSTEM</h1>
        <p class="lead">Eine Sichtbarkeitsplattform für junge Talente — Beobachtungs- und Bewertungsmöglichkeiten.</p>
        <p class="breadcrumb"><a asp-action="Index">Startseite</a> / Scout-System</p>
    </div>
</section>

<section class="content-section">
    <div class="container content-grid">
        <div class="content-text">
            <p>
                Die Junior League Cup zielt darauf ab, ein Umfeld zu schaffen, in dem Spieler nicht nur Spiele bestreiten, sondern auch beobachtet und bewertet werden.
                Scout-Teams, Trainer und Fußballprofis beim Event können das Entwicklungspotenzial der Spieler prüfen.
            </p>
            <div class="notice">
                Das Scout-System wird nicht als garantierter Transfer dargestellt. Es bietet ausschließlich Sichtbarkeits- und Bewertungsmöglichkeiten.
            </div>
        </div>
        <div class="content-image" style="background-image: url('https://images.unsplash.com/photo-1522778119026-d647f0596c20?w=900&q=80');" role="img" aria-label="Scout"></div>
    </div>
</section>

<section class="content-section section-muted">
    <div class="container">
        <div class="features-grid">
            <div class="feature-box"><h3>Spielerbeobachtungssystem</h3><p>Beobachtungen während Spiele und Training.</p></div>
            <div class="feature-box"><h3>Leistungsbewertung</h3><p>Technische und taktische Analysebereiche.</p></div>
            <div class="feature-box"><h3>Positionsbasierte Analyse</h3><p>Rollen- und positionsorientierte Bewertung.</p></div>
            <div class="feature-box"><h3>Technische Fähigkeiten</h3><p>Bewertung von Ballkontrolle, Passspiel und Schuss.</p></div>
            <div class="feature-box"><h3>Spielintelligenz</h3><p>Entscheidungsfindung und Positionierung.</p></div>
            <div class="feature-box"><h3>Teamfit</h3><p>Gruppendynamik und Kommunikation.</p></div>
            <div class="feature-box"><h3>Körperliche Entwicklung</h3><p>Altersgerechte körperliche Beobachtung.</p></div>
            <div class="feature-box"><h3>Entwicklungsbericht</h3><p>Optionen für zusammenfassende Bewertungsberichte.</p></div>
        </div>
    </div>
</section>
