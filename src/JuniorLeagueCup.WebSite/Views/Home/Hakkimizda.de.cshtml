@{
    ViewData["Title"] = "Über uns";
    ViewData["Description"] = "Über die Junior League Cup — eine Jugendfußball-Organisation der nächsten Generation unter Zenit Event und Zenit Tourism.";
}

<section class="page-hero">
    <div class="container">
        <h1>ÜBER UNS</h1>
        <p class="lead">Eine Jugendfußball-Organisation der nächsten Generation, entwickelt von Zenit Event.</p>
        <p class="breadcrumb"><a asp-action="Index">Startseite</a> / Über uns</p>
    </div>
</section>

<section class="content-section">
    <div class="container content-grid">
        <div class="content-image" style="background-image: url('https://images.unsplash.com/photo-1560272564-c83b66b1bd40?w=900&q=80');" role="img" aria-label="Fußballorganisation"></div>
        <div class="content-text">
            <span class="section-label">Zenit Event</span>
            <h2>Eine professionelle Organisationsmarke</h2>
            <p>
                Die Junior League Cup ist eine Jugendfußball-Organisation der nächsten Generation, entwickelt von Zenit Event unter dem Dach von Zenit Tourism.
                Das Projekt zielt darauf ab, ein nachhaltiges, professionelles Organisationsmodell zu schaffen, indem Sportevents, Medien, Tourismus
                und Jugendfußball-Entwicklung unter einem Dach vereint werden.
            </p>
            <ul class="check-list">
                <li>Regionale Auswahl und Finale in Antalya</li>
                <li>Scout-Sichtbarkeit und Medienreichweite</li>
                <li>Sponsoring- und Sporttourismus-Integration</li>
                <li>Markenstruktur bereit für internationales Wachstum</li>
            </ul>
        </div>
    </div>
</section>

<section class="content-section section-muted">
    <div class="container">
        <div class="cta-banner">
            <div class="cta-bg" aria-hidden="true"></div>
            <div class="cta-overlay" aria-hidden="true"></div>
            <div class="cta-content">
                <h2>WEG NACH ANTALYA</h2>
                <p>Eine professionelle Organisationsreise für die jungen Fußballtalente der Türkei.</p>
                <a asp-action="TakimBasvurusu" class="btn btn-gold">Teambewerbung</a>
                <a asp-action="Sponsorluk" class="btn btn-outline">Sponsor werden</a>
            </div>
        </div>
    </div>
</section>
