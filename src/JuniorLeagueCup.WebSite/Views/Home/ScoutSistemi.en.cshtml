@{
    ViewData["Title"] = "Scout System";
    ViewData["Description"] = "Junior League Cup scout system — visibility and evaluation opportunities for young talents.";
}

<section class="page-hero">
    <div class="container">
        <h1>SCOUT SYSTEM</h1>
        <p class="lead">A visibility platform for young talents — observation and evaluation opportunities.</p>
        <p class="breadcrumb"><a asp-action="Index">Home</a> / Scout System</p>
    </div>
</section>

<section class="content-section">
    <div class="container content-grid">
        <div class="content-text">
            <p>
                Junior League Cup aims to create an environment where players are not only playing matches but are also observed and evaluated.
                Scout teams, coaches, and football professionals at the event can review players' development potential.
            </p>
            <div class="notice">
                The scout system is not presented as a guaranteed transfer. It provides visibility and evaluation opportunities only.
            </div>
        </div>
        <div class="content-image" style="background-image: url('https://images.unsplash.com/photo-1522778119026-d647f0596c20?w=900&q=80');" role="img" aria-label="Scout"></div>
    </div>
</section>

<section class="content-section section-muted">
    <div class="container">
        <div class="features-grid">
            <div class="feature-box"><h3>Player Observation System</h3><p>In-match and training observations.</p></div>
            <div class="feature-box"><h3>Performance Evaluation</h3><p>Technical and tactical analysis areas.</p></div>
            <div class="feature-box"><h3>Position-Based Analysis</h3><p>Role and position-focused assessment.</p></div>
            <div class="feature-box"><h3>Technical Skills</h3><p>Ball control, passing, and shooting evaluation.</p></div>
            <div class="feature-box"><h3>Game Intelligence</h3><p>Decision-making and positioning.</p></div>
            <div class="feature-box"><h3>Team Fit</h3><p>Group dynamics and communication.</p></div>
            <div class="feature-box"><h3>Physical Development</h3><p>Age-appropriate physical observation.</p></div>
            <div class="feature-box"><h3>Development Report</h3><p>Summary evaluation report options.</p></div>
        </div>
    </div>
</section>
