@{
    ViewData["Title"] = "Antalya Final";
    ViewData["Description"] = "Junior League Cup Antalya final — professional pitches, hotel packages, scout area, and trophy ceremony.";
}

<section class="page-hero">
    <div class="container">
        <h1>GRAND FINAL IN ANTALYA</h1>
        <p class="lead">Teams advancing from regional selections compete in a professional football organization atmosphere.</p>
        <p class="breadcrumb"><a asp-action="Index">Home</a> / Antalya Final</p>
    </div>
</section>

<section class="content-section">
    <div class="container content-grid">
        <div class="content-image" style="background-image: url('https://images.unsplash.com/photo-1459865264687-595d652de67e?w=900&q=80');" role="img" aria-label="Antalya"></div>
        <div class="content-text">
            <p>
                Antalya is the main stage of Junior League Cup. Throughout the event, matches, scout evaluations, media production,
                award ceremonies, family activities, and sponsor activations take place.
            </p>
            <p>Approximately 40 teams experience the final excitement within a professional pitch and hotel organization framework.</p>
        </div>
    </div>
</section>

<section class="content-section section-muted">
    <div class="container">
        <div class="features-grid">
            <div class="feature-box"><div class="feature-icon">🏟</div><h3>Professional Pitches</h3><p>Match venues meeting international standards.</p></div>
            <div class="feature-box"><div class="feature-icon">🏨</div><h3>Hotels & Accommodation</h3><p>Team and family accommodation packages.</p></div>
            <div class="feature-box"><div class="feature-icon">🎬</div><h3>Opening Ceremony</h3><p>Professional opening and showcase program.</p></div>
            <div class="feature-box"><div class="feature-icon">⚽</div><h3>Group & Knockout Matches</h3><p>Full tournament schedule and fixtures.</p></div>
            <div class="feature-box"><div class="feature-icon">🏆</div><h3>Final & Trophy Ceremony</h3><p>Championship final and awards presentation.</p></div>
            <div class="feature-box"><div class="feature-icon">👁</div><h3>Scout Viewing Area</h3><p>Dedicated observation and evaluation zone.</p></div>
            <div class="feature-box"><div class="feature-icon">📺</div><h3>Media Interviews</h3><p>Professional content production.</p></div>
            <div class="feature-box"><div class="feature-icon">👨‍👩‍👧</div><h3>Family Activities</h3><p>Program for parents during the event.</p></div>
            <div class="feature-box"><div class="feature-icon">🤝</div><h3>Sponsor Activations</h3><p>Brand experience areas.</p></div>
        </div>
    </div>
</section>
