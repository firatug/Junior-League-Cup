@model IEnumerable<JuniorLeagueCup.WebSite.Models.NewsArticle>
@{
    ViewData["Title"] = "Haberler";
    ViewData["Description"] = "Junior League Cup haberleri ve duyuruları.";
}

<section class="page-hero">
    <div class="container">
        <h1>HABERLER</h1>
        <p class="lead">Junior League Cup güncel haberleri.</p>
        <p class="breadcrumb"><a asp-action="Index">Ana Sayfa</a> / Haberler</p>
    </div>
</section>

<section class="content-section">
    <div class="container">
        @await Html.PartialAsync("_NewsGrid", Model, new ViewDataDictionary(ViewData) { { "ShowCategory", false } })
    </div>
</section>
