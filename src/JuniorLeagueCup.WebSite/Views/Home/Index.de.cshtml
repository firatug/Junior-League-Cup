@model IEnumerable<JuniorLeagueCup.WebSite.Models.NewsArticle>
@{
    ViewData["Title"] = "Weg nach Antalya";
    ViewData["Description"] = "Junior League Cup — U7-U8-Fußballteams aus Städten in der gesamten Türkei qualifizieren sich über regionale Auswahlen für das Antalya-Finale.";
}

<section class="hero hero-split">
    <div class="hero-stadium" aria-hidden="true"></div>
    <div class="hero-fade" aria-hidden="true"></div>
    <div class="container hero-inner">
        <div class="hero-copy">
            <h1>
                Junior League Cup
                <span class="hero-highlight">Road to Antalya</span>
                2026
            </h1>
            <p class="hero-desc">
                Young talents aged 7–8 from cities across Turkey advance from regional selections
                to the Antalya final. Professional organization, scout visibility, and a family-focused sports tourism experience.
            </p>
            <div class="hero-actions">
                <a asp-action="TakimBasvurusu" class="btn btn-primary">Bewerben Sie Ihr Team</a>
                <a asp-action="BolgeselSecmeler" class="btn btn-white">Regionale Auswahlen</a>
            </div>
            <ul class="hero-features">
                <li>Professionelles Turnierformat für 7–8-Jährige</li>
                <li>Von regionalen Auswahlen bis zum Antalya-Finale</li>
                <li>Scout-Sichtbarkeit und Medieninhalte</li>
            </ul>
        </div>
        <p class="hero-watermark" aria-hidden="true">Junior League Cup</p>
    </div>
</section>

<div class="hero-cards-wrap">
    <div class="container">
        <div class="info-cards">
            <a class="info-card info-card--1" href="#jlc-nedir">
                <span class="info-card-num" aria-hidden="true">01</span>
                <div class="info-card-content">
                    <strong>Turnier für 7–8-Jährige</strong>
                    <span>Professionelles Format, altersgerechte Organisation</span>
                </div>
            </a>
            <a class="info-card info-card--2" href="#nasil-isler">
                <span class="info-card-num" aria-hidden="true">02</span>
                <div class="info-card-content">
                    <strong>Road to Antalya</strong>
                    <span>Von regionalen Auswahlen bis zum großen Finale</span>
                </div>
            </a>
            <a class="info-card info-card--3" href="#scout">
                <span class="info-card-num" aria-hidden="true">03</span>
                <div class="info-card-content">
                    <strong>Scouts & Medien</strong>
                    <span>Sichtbarkeit und professionelle Inhalte</span>
                </div>
            </a>
            <a class="info-card info-card--4" href="#efsane-bulusma">
                <span class="info-card-num" aria-hidden="true">04</span>
                <div class="info-card-content">
                    <strong>Legenden-Treffen</strong>
                    <span>Meet-and-Greet-Sessions mit Gastfußballern</span>
                </div>
            </a>
        </div>
</div>
</div>

<section id="jlc-nedir">
    <div class="container content-grid">
        <div class="content-image" style="background-image: url('https://images.unsplash.com/photo-1579952363873-27f3bade9f55?w=900&q=80');" role="img" aria-label="Junior League Cup Organisation"></div>
        <div class="content-text">
            <span class="section-label">Was ist JLC?</span>
            <h2>Wo zukünftige Stars beginnen</h2>
            <p>
                Junior League Cup is more than a tournament where children simply play matches. It is a next-generation football organization
                where young players experience a professional football atmosphere, are observed by scout teams, gain media visibility,
                and enjoy an unforgettable sports tourism experience with their families.
            </p>
            <ul class="check-list">
                <li>Jugendfußball-Entwicklung</li>
                <li>Professionelles Organisationserlebnis</li>
                <li>Regionale Auswahlen und Antalya-Finale</li>
                <li>Scout-Berichte und Sichtbarkeit</li>
                <li>Familien- und vereinsorientierte Struktur</li>
            </ul>
            <a asp-action="JlcNedir" class="btn btn-primary" style="margin-top:1.5rem;">Mehr erfahren</a>
        </div>
    </div>
</section>

<section class="section-muted" id="nasil-isler">
    <div class="container">
        <div class="section-header">
            <span class="section-label">Organisation</span>
            <h2>Road to Antalya: Die JLC-Reise</h2>
            <p>Der professionelle Organisationsprozess von regionalen Auswahlen bis zur Meisterschaft.</p>
        </div>
        <div class="timeline" id="jlcTimeline">
            <div class="timeline-track" aria-hidden="true">
                <div class="timeline-line"></div>
                <div class="timeline-line-progress"></div>
                <span class="timeline-arrow">›</span>
                <span class="timeline-arrow">›</span>
                <span class="timeline-arrow">›</span>
                <span class="timeline-arrow">›</span>
            </div>
            <div class="timeline-step">
                <div class="timeline-num">01</div>
                <h3>Regionale Auswahlen</h3>
                <p>Auswahlen unter Vereinen und Fußballschulen in Istanbul, Ankara, Izmir, Bursa, Adana und weiteren Städten.</p>
            </div>
            <div class="timeline-step">
                <div class="timeline-num">02</div>
                <h3>Regionalmeister</h3>
                <p>Erfolgreiche Teams in jeder Region erhalten das Recht, am Antalya-Finale teilzunehmen.</p>
            </div>
            <div class="timeline-step">
                <div class="timeline-num">03</div>
                <h3>Antalya-Finale</h3>
                <p>Etwa 40 Teams treten im Rahmen einer professionellen Platz- und Hotelorganisation an.</p>
            </div>
            <div class="timeline-step">
                <div class="timeline-num">04</div>
                <h3>Scouts & Medien</h3>
                <p>Spieler gewinnen Sichtbarkeit vor Scout-Teams, Medien und Sponsorenmarken.</p>
            </div>
            <div class="timeline-step">
                <div class="timeline-num">05</div>
                <h3>JLC-Meister</h3>
                <p>Der Junior League Cup-Meister wird nach den Finalspielen gekürt.</p>
            </div>
        </div>
    </div>
</section>

<section id="harita">
    <div class="container map-section">
        <div class="content-text">
            <span class="section-label">Regionale Auswahlen</span>
            <h2>Türkische Talente treffen sich in Antalya</h2>
            <p>
                Regional selections are the first step on the Junior League Cup journey. Successful teams in each region
                earn the right to participate in the Antalya final.
            </p>
            <a asp-action="BolgeselSecmeler" class="btn btn-primary" style="margin-top:1.25rem;">Städte entdecken</a>
        </div>
        <div class="map-visual" aria-hidden="true">
            <partial name="_TurkeyMap" />
        </div>
    </div>
</section>

<section class="section-muted" id="antalya">
    <div class="container content-grid">
        <div class="content-image" style="background-image: url('https://images.unsplash.com/photo-1459865264687-595d652de67e?w=900&q=80');" role="img" aria-label="Antalya-Finale Organisation"></div>
        <div class="content-text">
            <span class="section-label">Antalya-Finale</span>
            <h2>Das große Finale in Antalya</h2>
            <p>
                Antalya is the main stage of Junior League Cup. Teams advancing from regional selections compete
                in a professional football organization atmosphere. Matches, scout evaluations, media production,
                award ceremonies, and family activities come together in one experience.
            </p>
            <ul class="check-list">
                <li>Professionelle Plätze und Hotelorganisation</li>
                <li>Gruppen-, K.o.- und Finalspiele</li>
                <li>Scout-Beobachtungsbereich und Medieninterviews</li>
                <li>Pokalverleihung und Familienaktivitäten</li>
            </ul>
            <a asp-action="AntalyaFinali" class="btn btn-primary" style="margin-top:1.25rem;">Finale-Erlebnis entdecken</a>
        </div>
    </div>
</section>

<section id="scout">
    <div class="container content-grid reverse">
        <div class="content-image" style="background-image: url('https://images.unsplash.com/photo-1522778119026-d647f0596c20?w=900&q=80');" role="img" aria-label="Scout-Bewertung"></div>
        <div class="content-text">
            <span class="section-label">Scout-System</span>
            <h2>Eine Sichtbarkeitsplattform für junge Talente</h2>
            <p>
                Junior League Cup aims to create an environment where players are observed and evaluated.
                Scout teams and football professionals have the opportunity to review development potential.
            </p>
            <div class="notice">
                Das Scout-System ist kein garantiertes Transferversprechen; es bietet Sichtbarkeit und Bewertungsmöglichkeiten.
            </div>
            <a href="#efsane-bulusma" class="btn btn-outline-dark" style="margin-right:0.75rem;">Legenden-Treffen-Programm</a>
            <a asp-action="ScoutSistemi" class="btn btn-primary">Scout-System entdecken</a>
        </div>
    </div>
</section>

<section class="section-muted" id="efsane-bulusma">
    <div class="container content-grid">
        <div class="content-image content-image--legend" style="background-image: url('@Url.Content("~/images/ronaldinho.png")');" role="img" aria-label="Ronaldinho — Legenden-Treffen"></div>
        <div class="content-text">
            <span class="section-label">Sichtbarkeitsprogramm</span>
            <h2>Legenden-Treffen</h2>
            <p>
                During the Antalya final, short meet-and-greet and experience-sharing sessions are held with guest footballers
                according to the organization schedule. Young players find inspiration; clubs and parents can take part in the program.
            </p>
            <ul class="check-list">
                <li>Meet-and-Greet- und Motivationssessions</li>
                <li>Gelegenheit, Karrieregeschichten zu hören</li>
            </ul>
            <div class="notice">
                Beinhaltet keine Transfer- oder Vereinsverpflichtungen. Gastnamen und Programmdetails werden gemäß Zeitplan bekannt gegeben.
            </div>
            <a asp-action="AntalyaFinali" class="btn btn-primary" style="margin-top:1.25rem;">Antalya-Finale</a>
        </div>
    </div>
</section>

<section class="section-muted" id="veli">
    <div class="container">
        <div class="section-header">
            <span class="section-label">Eltern & Spieler</span>
            <h2>Mehr als ein Turnier für Ihr Kind</h2>
            <p>Professionelle Platzatmosphäre, Medieninhalte und ein familienorientiertes Organisationserlebnis.</p>
        </div>
        <div class="package-grid">
            <div class="package-card">
                <h3>Standard-Erlebnis</h3>
                <p class="package-desc">Organisationsteilnahme und Kernspielprogramm.</p>
                <ul>
                    <li>Organisationsteilnahme</li>
                    <li>Spielprogramm und Team-Spielplan</li>
                    <li>Grundlegende mediale Sichtbarkeit</li>
                </ul>
            </div>
            <div class="package-card featured">
                <h3>Premium-Spieler</h3>
                <p class="package-desc">Erweitertes Medien- und Spielerkarten-Erlebnis.</p>
                <ul>
                    <li>Professionelles Fotoshooting</li>
                    <li>Persönliche Spielerkarte</li>
                    <li>Kurzvideo-Inhalte</li>
                    <li>Leistungsbericht</li>
                </ul>
            </div>
            <div class="package-card">
                <h3>Elite Scout</h3>
                <p class="package-desc">Detailliertes Profil und Scout-Bewertungsbereich.</p>
                <ul>
                    <li>Detailliertes Spielerprofil</li>
                    <li>Scout-Bewertungsbericht</li>
                    <li>Exklusive Medieninhalte</li>
                    <li>Interview- / Showcase-Bereich</li>
                </ul>
            </div>
        </div>
        <p style="text-align:center;margin-top:2rem;color:var(--text-muted);font-size:0.9rem;">
            Paketdetails und Preise werden über das Verwaltungspanel aktualisiert.
            <a asp-action="VeliOyuncuDeneyimi" style="color:var(--accent);font-weight:600;"> Alle Pakete ansehen →</a>
        </p>
    </div>
</section>

<section id="sponsor">
    <div class="container">
        <div class="section-header">
            <span class="section-label">Sponsoring</span>
            <h2>Platzieren Sie Ihre Marke in der Zukunftsgeschichte des Fußballs</h2>
            <p>Eine starke Sponsoring-Plattform, die Jugendfußball, Familienerlebnis, mediale Sichtbarkeit und Sporttourismus vereint.</p>
        </div>
        <div class="sponsor-grid">
            <div class="sponsor-tier"><h3>Titelsponsor</h3><ul><li>Logo- und Web-Sichtbarkeit</li><li>Präsenz vor Ort</li><li>Medieninhalte</li></ul></div>
            <div class="sponsor-tier"><h3>Regionaler Sponsor</h3><ul><li>Städtische Aktivierung</li><li>Social Media</li><li>Sichtbarkeit am Spielfeldrand</li></ul></div>
            <div class="sponsor-tier"><h3>Ausrüstungssponsor</h3><ul><li>Platzierung auf Teamtrikots</li><li>Foto und Video</li><li>Markenaktivierung</li></ul></div>
            <div class="sponsor-tier"><h3>Mediensponsor</h3><ul><li>Content-Sponsoring</li><li>Interview-Bereiche</li><li>Digitale Übertragung</li></ul></div>
        </div>
        <div style="text-align:center;margin-top:2.5rem;">
            <a asp-action="Sponsorluk" class="btn btn-primary">Sponsoring-Unterlagen anfordern</a>
        </div>
    </div>
</section>

<section class="section-muted" id="medya">
    <div class="container">
        <div class="section-header">
            <span class="section-label">Nachrichten</span>
            <h2>Road to Antalya Inhalte</h2>
            <p>Nachrichten, Interviews, Foto- und Videogalerien — eine lebendige Medienplattform.</p>
        </div>
        @await Html.PartialAsync("_NewsGrid", Model)
        </div>
        <div style="text-align:center;margin-top:2rem;">
            <a asp-action="Medya" class="btn btn-outline-dark">Alle Nachrichten & Medien</a>
        </div>
    </div>
</section>

<section id="oteller">
    <div class="container">
        <div class="section-header">
            <span class="section-label">Unterkunft</span>
            <h2>Fußball- und Urlaubserlebnis in Antalya</h2>
            <p>Das JLC Antalya-Finale verbindet Fußballbegeisterung mit Antalyas Tourismusstärke.</p>
        </div>
        <div class="hotel-grid">
            <div class="hotel-card"><h3>Kremlin Palace</h3><p class="region">Kundu</p><p>Partnerhotel — Unterkunfts- und Transferpakete.</p></div>
            <div class="hotel-card"><h3>Limak Lara</h3><p class="region">Lara</p><p>Organisations-Unterkunftspartner.</p></div>
            <div class="hotel-card"><h3>Fame Lara</h3><p class="region">Lara</p><p>Unterkunftsoption für Familien und Teams.</p></div>
            
        </div>
        <div style="text-align:center;margin-top:2rem;">
            <a asp-action="Oteller" class="btn btn-outline-dark">Alle Hotels</a>
        </div>
    </div>
</section>

<section class="section-muted">
    <div class="container">
        <div class="cta-banner">
            <div class="cta-bg" aria-hidden="true"></div>
            <div class="cta-overlay" aria-hidden="true"></div>
            <div class="cta-content">
                <h2>VON LOKALEN TRÄUMEN ZUR GROßEN BÜHNE</h2>
                <p>Lassen Sie Ihre Fußballschule oder Ihren Verein an der Junior League Cup-Reise teilnehmen. Voranmeldung für regionale Auswahlen.</p>
                <a asp-action="TakimBasvurusu" class="btn btn-gold">Bewerben Sie Ihr Team</a>
                <a asp-action="Iletisim" class="btn btn-outline">Kontaktieren Sie uns</a>
            </div>
        </div>
    </div>
</section>
