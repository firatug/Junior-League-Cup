@model JuniorLeagueCup.WebSite.Models.TakimBasvurusuFormModel
@{
    ViewData["Title"] = "Takım ve Kulüp Başvurusu";
    ViewData["Description"] = "Junior League Cup takım başvuru formu — futbol okulları ve kulüpler için bölgesel seçme ön kaydı.";
}

<section class="page-hero">
    <div class="container">
        <h1>TAKIM BAŞVURUSU</h1>
        <p class="lead">Futbol okulları ve kulüpler başvuru formunu doldurarak bölgesel seçmeler için ön kayıt oluşturabilir.</p>
        <p class="breadcrumb"><a asp-action="Index">Ana Sayfa</a> / Takım Başvurusu</p>
    </div>
</section>

<section class="content-section">
    <div class="container">
        <form class="apply-form" asp-action="TakimBasvurusuPost" method="post">
            <div asp-validation-summary="All" class="admin-alert admin-alert-error" style="margin-bottom:1rem;"></div>
            <div class="form-row">
                <div class="form-group">
                    <label asp-for="ClubName"></label>
                    <input asp-for="ClubName" />
                    <span asp-validation-for="ClubName" class="admin-field-error"></span>
                </div>
                <div class="form-group">
                    <label asp-for="ContactName"></label>
                    <input asp-for="ContactName" />
                    <span asp-validation-for="ContactName" class="admin-field-error"></span>
                </div>
            </div>
            <div class="form-row">
                <div class="form-group">
                    <label asp-for="Phone"></label>
                    <input asp-for="Phone" type="tel" />
                    <span asp-validation-for="Phone" class="admin-field-error"></span>
                </div>
                <div class="form-group">
                    <label asp-for="Email"></label>
                    <input asp-for="Email" type="email" />
                    <span asp-validation-for="Email" class="admin-field-error"></span>
                </div>
            </div>
            <div class="form-row">
                <div class="form-group">
                    <label asp-for="City"></label>
                    <select asp-for="City">
                        <option value="">Seçiniz</option>
                        <option>İstanbul</option>
                        <option>Ankara</option>
                        <option>İzmir</option>
                        <option>Bursa</option>
                        <option>Adana</option>
                        <option>Antalya</option>
                        <option>Diğer</option>
                    </select>
                    <span asp-validation-for="City" class="admin-field-error"></span>
                </div>
                <div class="form-group">
                    <label asp-for="AgeGroup"></label>
                    <select asp-for="AgeGroup">
                        <option value="">Seçiniz</option>
                        <option>7 Yaş</option>
                        <option>8 Yaş</option>
                    </select>
                    <span asp-validation-for="AgeGroup" class="admin-field-error"></span>
                </div>
            </div>
            <div class="form-group">
                <label asp-for="PlayerCount"></label>
                <input asp-for="PlayerCount" min="8" max="20" />
            </div>
            <div class="form-group">
                <label asp-for="PastEvents"></label>
                <textarea asp-for="PastEvents" rows="3"></textarea>
            </div>
            <div class="form-group">
                <label asp-for="Notes"></label>
                <textarea asp-for="Notes" rows="3"></textarea>
            </div>
            <div class="form-check">
                <input asp-for="Kvkk" />
                <label asp-for="Kvkk"><a asp-action="Kvkk" target="_blank">KVKK aydınlatma metnini</a> okudum ve kişisel verilerimin işlenmesini onaylıyorum.</label>
                <span asp-validation-for="Kvkk" class="admin-field-error"></span>
            </div>
            <div class="form-check">
                <input asp-for="Cerez" />
                <label asp-for="Cerez"><a asp-action="CerezPolitikasi" target="_blank">Çerez politikasını</a> okudum ve kabul ediyorum.</label>
                <span asp-validation-for="Cerez" class="admin-field-error"></span>
            </div>
            <button type="submit" class="btn btn-primary" style="margin-top:1rem;">Başvuruyu Gönder</button>
        </form>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
