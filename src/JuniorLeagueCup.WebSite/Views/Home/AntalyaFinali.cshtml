@{
    ViewData["Title"] = "Antalya Final Organizasyonu";
    ViewData["Description"] = "Junior League Cup Antalya finali — profesyonel sahalar, otel organizasyonu, scout alanı ve kupa töreni.";
}

<section class="page-hero">
    <div class="container">
        <h1>BÜYÜK FİNAL ANTALYA'DA</h1>
        <p class="lead">Bölgesel seçmelerden gelen takımlar profesyonel futbol organizasyonu atmosferinde karşılaşır.</p>
        <p class="breadcrumb"><a asp-action="Index">Ana Sayfa</a> / Antalya Finali</p>
    </div>
</section>

<section class="content-section">
    <div class="container content-grid">
        <div class="content-image" style="background-image: url('https://images.unsplash.com/photo-1459865264687-595d652de67e?w=900&q=80');" role="img" aria-label="Antalya"></div>
        <div class="content-text">
            <p>
                Antalya, Junior League Cup'ın ana sahnesidir. Organizasyon boyunca maçlar, scout değerlendirmeleri, medya çekimleri,
                ödül törenleri, aile etkinlikleri ve sponsor aktiviteleri gerçekleştirilir.
            </p>
            <p>Yaklaşık 40 takım, profesyonel saha ve otel organizasyonu içerisinde final heyecanını yaşar.</p>
        </div>
    </div>
</section>

