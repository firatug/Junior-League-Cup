@{
    ViewData["Title"] = "İletişim";
    ViewData["Description"] = "Junior League Cup iletişim — takım başvurusu, sponsorluk, scout iş birliği ve genel bilgi.";
    var success = ViewBag.FormSuccess as bool? == true;
}

<section class="page-hero">
    <div class="container">
        <h1>İLETİŞİM</h1>
        <p class="lead">Sorularınız ve iş birliği talepleriniz için bize ulaşın.</p>
        <p class="breadcrumb"><a asp-action="Index">Ana Sayfa</a> / İletişim</p>
    </div>
</section>

<section class="content-section">
    <div class="container contact-grid">
        <div class="contact-info-card">
            <div class="contact-item">
                <div class="icon" aria-hidden="true">📍</div>
                <div>
                    <strong>Adres</strong>
                    <span>Çağlayan Mah. Fener Caddesi No.48 D.1<br />Muratpaşa / Antalya</span>
                </div>
            </div>
            <div class="contact-item">
                <div class="icon" aria-hidden="true">📞</div>
                <div><strong>Telefon</strong><span><a href="tel:+902423240354">0242 324 03 54</a></span></div>
            </div>
            <div class="contact-item">
                <div class="icon" aria-hidden="true">✉️</div>
                <div><strong>E-posta</strong><span><a href="mailto:info@juniorleaguecup.com">info@juniorleaguecup.com</a></span></div>
            </div>
            <div class="contact-item">
                <div class="icon" aria-hidden="true">🏢</div>
                <div>
                    <strong>Organizasyon</strong>
                    <span>Zenit Event — Junior League Cup<br />ATA Ventures markası</span>
                </div>
            </div>
            <p style="margin-top:1.5rem;font-size:0.9rem;color:var(--text-muted);">
                Takım başvurusu için <a asp-action="TakimBasvurusu" style="color:var(--accent);font-weight:600;">başvuru formunu</a> kullanabilirsiniz.
            </p>
        </div>

        @if (success)
        {
            <div class="notice" style="grid-column:1/-1;">Mesajınız alındı. En kısa sürede size dönüş yapacağız.</div>
        }

        <form class="contact-form" method="post" asp-action="IletisimPost">
            <div class="form-row">
                <div class="form-group"><label for="fullName">Ad Soyad</label><input type="text" id="fullName" name="fullName" required /></div>
                <div class="form-group"><label for="phone">Telefon</label><input type="tel" id="phone" name="phone" required /></div>
            </div>
            <div class="form-group"><label for="email">E-posta</label><input type="email" id="email" name="email" required /></div>
            <div class="form-group">
                <label for="subject">Konu</label>
                <select id="subject" name="subject" required>
                    <option value="">Seçiniz</option>
                    <option>Takım Başvurusu</option>
                    <option>Sponsorluk</option>
                    <option>Scout İş Birliği</option>
                    <option>Otel Partnerliği</option>
                    <option>Medya</option>
                    <option>Genel Bilgi</option>
                </select>
            </div>
            <div class="form-group"><label for="message">Mesaj</label><textarea id="message" name="message" required></textarea></div>
            <div class="form-check">
                <input type="checkbox" id="kvkk" name="kvkk" required />
                <label for="kvkk"><a asp-action="Kvkk" target="_blank">KVKK aydınlatma metnini</a> okudum ve onaylıyorum.</label>
            </div>
            <div class="form-check">
                <input type="checkbox" id="cerez" name="cerez" required />
                <label for="cerez"><a asp-action="CerezPolitikasi" target="_blank">Çerez politikasını</a> okudum ve kabul ediyorum.</label>
            </div>
            <button type="submit" class="btn btn-primary">Gönder</button>
        </form>
    </div>
</section>
