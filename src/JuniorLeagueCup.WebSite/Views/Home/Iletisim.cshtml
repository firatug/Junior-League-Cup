@model JuniorLeagueCup.WebSite.Models.IletisimFormModel
@{
    ViewData["Title"] = "İletişim";
    ViewData["Description"] = "Junior League Cup iletişim — takım başvurusu, sponsorluk, scout iş birliği ve genel bilgi.";
}

<section class="page-hero">
    <div class="container">
        <h1>İLETİŞİM</h1>
        <p class="lead">Sorularınız ve iş birliği talepleriniz için bize ulaşın.</p>
        <p class="breadcrumb"><a asp-action="Index">Ana Sayfa</a> / İletişim</p>
    </div>
</section>

<section class="content-section">
    <div class="container contact-grid">
        <div class="contact-info-card">
            <div class="contact-item">
                <div class="icon" aria-hidden="true">📍</div>
                <div>
                    <strong>Adres</strong>
                    <span>Çağlayan Mah. Fener Caddesi No.48 D.1<br />Muratpaşa / Antalya</span>
                </div>
            </div>
            <div class="contact-item">
                <div class="icon" aria-hidden="true">📞</div>
                <div><strong>Telefon</strong><span><a href="tel:+902423240354">0242 324 03 54</a></span></div>
            </div>
            <div class="contact-item">
                <div class="icon" aria-hidden="true">✉️</div>
                <div><strong>E-posta</strong><span><a href="mailto:info@juniorleaguecup.com">info@juniorleaguecup.com</a></span></div>
            </div>
            <div class="contact-item">
                <div class="icon" aria-hidden="true">🏢</div>
                <div>
                    <strong>Organizasyon</strong>
                    <span>Zenit Event — Junior League Cup<br />ATA Ventures markası</span>
                </div>
            </div>
            <p style="margin-top:1.5rem;font-size:0.9rem;color:var(--text-muted);">
                Takım başvurusu için <a asp-action="TakimBasvurusu" style="color:var(--accent);font-weight:600;">başvuru formunu</a> kullanabilirsiniz.
            </p>
        </div>

        <form class="contact-form" asp-action="IletisimPost" method="post">
            <div asp-validation-summary="All" class="admin-alert admin-alert-error" style="margin-bottom:1rem;"></div>
            <div class="form-row">
                <div class="form-group">
                    <label asp-for="FullName"></label>
                    <input asp-for="FullName" />
                    <span asp-validation-for="FullName" class="admin-field-error"></span>
                </div>
                <div class="form-group">
                    <label asp-for="Phone"></label>
                    <input asp-for="Phone" type="tel" />
                    <span asp-validation-for="Phone" class="admin-field-error"></span>
                </div>
            </div>
            <div class="form-group">
                <label asp-for="Email"></label>
                <input asp-for="Email" type="email" />
                <span asp-validation-for="Email" class="admin-field-error"></span>
            </div>
            <div class="form-group">
                <label asp-for="Subject"></label>
                <select asp-for="Subject">
                    <option value="">Seçiniz</option>
                    <option>Takım Başvurusu</option>
                    <option>Sponsorluk</option>
                    <option>Scout İş Birliği</option>
                    <option>Otel Partnerliği</option>
                    <option>Medya</option>
                    <option>Genel Bilgi</option>
                </select>
                <span asp-validation-for="Subject" class="admin-field-error"></span>
            </div>
            <div class="form-group">
                <label asp-for="Message"></label>
                <textarea asp-for="Message"></textarea>
                <span asp-validation-for="Message" class="admin-field-error"></span>
            </div>
            <div class="form-check">
                <input asp-for="Kvkk" />
                <label asp-for="Kvkk"><a asp-action="Kvkk" target="_blank">KVKK aydınlatma metnini</a> okudum ve onaylıyorum.</label>
                <span asp-validation-for="Kvkk" class="admin-field-error"></span>
            </div>
            <div class="form-check">
                <input asp-for="Cerez" />
                <label asp-for="Cerez"><a asp-action="CerezPolitikasi" target="_blank">Çerez politikasını</a> okudum ve kabul ediyorum.</label>
                <span asp-validation-for="Cerez" class="admin-field-error"></span>
            </div>
            <button type="submit" class="btn btn-primary">Gönder</button>
        </form>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
