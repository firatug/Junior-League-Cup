@{
    ViewData["Title"] = "Experiencia de padres y jugadores";
    ViewData["Description"] = "Paquetes de experiencia para padres y jugadores Junior League Cup — campos profesionales, contenido mediático y visibilidad para scouts.";
}

<section class="page-hero">
    <div class="container">
        <h1>EXPERIENCIA DE PADRES Y JUGADORES</h1>
        <p class="lead">Más que un torneo para tu hijo — una experiencia futbolística inolvidable.</p>
        <p class="breadcrumb"><a asp-action="Index">Inicio</a> / Experiencia de padres y jugadores</p>
    </div>
</section>

<section class="content-section">
    <div class="container">
        <div class="features-grid" style="margin-bottom:3rem;">
            <div class="feature-box"><div class="feature-icon">🏟</div><h3>Ambiente de campo profesional</h3><p>Experiencia de partido según estándares de la organización.</p></div>
            <div class="feature-box"><div class="feature-icon">📸</div><h3>Foto y vídeo</h3><p>Sesiones de jugadores y contenido mediático.</p></div>
            <div class="feature-box"><div class="feature-icon">🪪</div><h3>Tarjeta personal del jugador</h3><p>Perfil digital e impreso del jugador.</p></div>
            <div class="feature-box"><div class="feature-icon">📊</div><h3>Evaluación del rendimiento</h3><p>Opciones de informes orientados al desarrollo.</p></div>
            <div class="feature-box"><div class="feature-icon">👁</div><h3>Visibilidad para scouts</h3><p>Oportunidad de observación y evaluación.</p></div>
            <div class="feature-box"><div class="feature-icon">🏨</div><h3>Alojamiento familiar</h3><p>Experiencia de organización y evento en Antalya.</p></div>
        </div>
        <div class="package-grid">
            <div class="package-card">
                <h3>Paquete Experiencia Estándar</h3>
                <p class="package-desc">Participación básica en la organización.</p>
                <ul>
                    <li>Participación en la organización</li>
                    <li>Programa de partidos</li>
                    <li>Calendario del equipo</li>
                    <li>Visibilidad mediática básica</li>
                </ul>
            </div>
            <div class="package-card featured">
                <h3>Paquete Jugador Premium</h3>
                <p class="package-desc">Medios y perfil mejorados.</p>
                <ul>
                    <li>Sesión fotográfica profesional</li>
                    <li>Tarjeta de jugador</li>
                    <li>Contenido de vídeo breve</li>
                    <li>Informe de rendimiento</li>
                </ul>
            </div>
            <div class="package-card">
                <h3>Paquete Elite Scout</h3>
                <p class="package-desc">Perfil detallado y zona de scouts.</p>
                <ul>
                    <li>Perfil detallado del jugador</li>
                    <li>Informe de evaluación de scouts</li>
                    <li>Contenido mediático exclusivo</li>
                    <li>Área de entrevista / presentación</li>
                </ul>
            </div>
        </div>
        <p style="text-align:center;margin-top:2rem;color:var(--text-muted);">Los precios se actualizarán desde el panel de administración.</p>
    </div>
</section>
