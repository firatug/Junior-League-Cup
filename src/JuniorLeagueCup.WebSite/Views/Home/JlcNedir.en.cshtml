@{
    ViewData["Title"] = "What is JLC?";
    ViewData["Description"] = "What is Junior League Cup? Regional selections, Antalya final, scout visibility, and professional youth football organization.";
}

<section class="page-hero">
    <div class="container">
        <h1>WHAT IS JLC?</h1>
        <p class="lead">A next-generation youth football organization — development, visibility, and a professional experience.</p>
        <p class="breadcrumb"><a asp-action="Index">Home</a> / What is JLC?</p>
    </div>
</section>

<section class="content-section">
    <div class="container content-grid">
        <div class="content-text">
            <p>
                Junior League Cup is more than a tournament where children simply play matches. It is a next-generation football organization
                where young players experience a professional football atmosphere, are observed by scout teams, gain media visibility,
                and enjoy an unforgettable sports tourism experience with their families.
            </p>
            <p>
                Developed by Zenit Event under the Zenit Tourism umbrella, the project brings together sports organization, media, tourism,
                and youth football development under one roof.
            </p>
        </div>
        <div class="content-image" style="background-image: url('https://images.unsplash.com/photo-1579952363873-27f3bade9f55?w=900&q=80');" role="img" aria-label="JLC organization"></div>
    </div>
</section>

<section class="content-section section-muted">
    <div class="container">
        <div class="section-header">
            <h2>Core Pillars of the Organization</h2>
        </div>
        <div class="features-grid">
            <div class="feature-box"><div class="feature-icon">⚽</div><h3>Youth Football Development</h3><p>Age-appropriate format and professional pitch standards.</p></div>
            <div class="feature-box"><div class="feature-icon">🏟</div><h3>Professional Organization</h3><p>Process management planned with a UEFA youth tournament atmosphere.</p></div>
            <div class="feature-box"><div class="feature-icon">📍</div><h3>Regional Selections</h3><p>City-based qualifiers and evaluation across Turkey.</p></div>
            <div class="feature-box"><div class="feature-icon">🏆</div><h3>Antalya Final</h3><p>Grand final event and championship experience.</p></div>
            <div class="feature-box"><div class="feature-icon">👁</div><h3>Scout Visibility</h3><p>Observation and evaluation opportunity — not a transfer guarantee.</p></div>
            <div class="feature-box"><div class="feature-icon">👨‍👩‍👧</div><h3>Family & Club Focused</h3><p>A sustainable experience model for parents and clubs.</p></div>
        </div>
    </div>
</section>
