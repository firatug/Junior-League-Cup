@model IEnumerable<JuniorLeagueCup.WebSite.Models.NewsArticle>
@{
    ViewData["Title"] = "Road to Antalya";
    ViewData["Description"] = "Junior League Cup — Türkiye'nin farklı şehirlerinden 7-8 yaş futbol takımları bölgesel seçmelerle Antalya finaline uzanıyor.";
}

<section class="hero hero-split">
    <div class="hero-stadium" aria-hidden="true"></div>
    <div class="hero-fade" aria-hidden="true"></div>
    <div class="container hero-inner">
        <div class="hero-copy">
            <h1>
                Junior League Cup
                <span class="hero-highlight">Road to Antalya</span>
                2026
            </h1>
            <p class="hero-desc">
                Türkiye'nin farklı şehirlerinden gelen 7-8 yaş genç yetenekler, bölgesel seçmelerden
                Antalya finaline uzanıyor. Profesyonel organizasyon, scout görünürlüğü ve aile odaklı spor turizmi deneyimi.
            </p>
            <div class="hero-actions">
                <a asp-action="TakimBasvurusu" class="btn btn-primary">Takım Başvurusu Yap</a>
                <a asp-action="BolgeselSecmeler" class="btn btn-white">Bölgesel Seçmeler</a>
            </div>
            <ul class="hero-features">
                <li>7-8 yaş profesyonel turnuva formatı</li>
                <li>Bölgesel seçmelerden Antalya finaline</li>
                <li>Scout görünürlüğü ve medya içerikleri</li>
            </ul>
        </div>
        <p class="hero-watermark" aria-hidden="true">Junior League Cup</p>
    </div>
</section>

<div class="hero-cards-wrap">
    <div class="container">
        <div class="info-cards">
            <a class="info-card info-card--1" href="#jlc-nedir">
                <span class="info-card-num" aria-hidden="true">01</span>
                <div class="info-card-content">
                    <strong>7-8 Yaş Turnuvası</strong>
                    <span>Profesyonel format, yaş grubuna uygun organizasyon</span>
                </div>
            </a>
            <a class="info-card info-card--2" href="#nasil-isler">
                <span class="info-card-num" aria-hidden="true">02</span>
                <div class="info-card-content">
                    <strong>Road to Antalya</strong>
                    <span>Bölgesel seçmelerden büyük finale</span>
                </div>
            </a>
            <a class="info-card info-card--3" href="#scout">
                <span class="info-card-num" aria-hidden="true">03</span>
                <div class="info-card-content">
                    <strong>Scout & Medya</strong>
                    <span>Görünürlük ve profesyonel içerik</span>
                </div>
            </a>
            <a class="info-card info-card--4" href="#efsane-bulusma">
                <span class="info-card-num" aria-hidden="true">04</span>
                <div class="info-card-content">
                    <strong>Efsane Buluşma</strong>
                    <span>Konuk futbolcularla tanışma oturumları</span>
                </div>
            </a>
        </div>
</div>
</div>

<section id="jlc-nedir">
    <div class="container content-grid">
        <div class="content-image" style="background-image: url('https://images.unsplash.com/photo-1579952363873-27f3bade9f55?w=900&q=80');" role="img" aria-label="Junior League Cup organizasyonu"></div>
        <div class="content-text">
            <span class="section-label">JLC Nedir?</span>
            <h2>Geleceğin Oyuncuları Burada Başlar</h2>
            <p>
                Junior League Cup, çocukların yalnızca maç yaptığı bir turnuva değil; profesyonel futbol atmosferini deneyimlediği,
                scout ekipleri tarafından izlenebildiği, medya görünürlüğü kazandığı ve aileleriyle birlikte unutulmaz bir spor turizmi deneyimi yaşadığı yeni nesil futbol organizasyonudur.
            </p>
            <ul class="check-list">
                <li>Çocuk futbol gelişimi</li>
                <li>Profesyonel organizasyon deneyimi</li>
                <li>Bölgesel seçmeler ve Antalya finali</li>
                <li>Scout raporları ve görünürlük</li>
                <li>Aile ve kulüp odaklı yapı</li>
            </ul>
            <a asp-action="JlcNedir" class="btn btn-primary" style="margin-top:1.5rem;">Detaylı Bilgi</a>
        </div>
    </div>
</section>

<section class="section-muted" id="nasil-isler">
    <div class="container">
        <div class="section-header">
            <span class="section-label">Organizasyon</span>
            <h2>Road to Antalya: JLC Yolculuğu</h2>
            <p>Bölgesel seçmelerden şampiyonluğa uzanan profesyonel organizasyon süreci.</p>
        </div>
        <div class="timeline" id="jlcTimeline">
            <div class="timeline-track" aria-hidden="true">
                <div class="timeline-line"></div>
                <div class="timeline-line-progress"></div>
                <span class="timeline-arrow">›</span>
                <span class="timeline-arrow">›</span>
                <span class="timeline-arrow">›</span>
                <span class="timeline-arrow">›</span>
            </div>
            <div class="timeline-step">
                <div class="timeline-num">01</div>
                <h3>Bölgesel Seçmeler</h3>
                <p>İstanbul, Ankara, İzmir, Bursa, Adana ve diğer şehirlerde kulüp ve futbol okulları arasında seçmeler.</p>
            </div>
            <div class="timeline-step">
                <div class="timeline-num">02</div>
                <h3>Bölge Şampiyonları</h3>
                <p>Her bölgede başarılı takımlar Antalya final organizasyonuna katılma hakkı kazanır.</p>
            </div>
            <div class="timeline-step">
                <div class="timeline-num">03</div>
                <h3>Antalya Finali</h3>
                <p>Yaklaşık 40 takım profesyonel saha ve otel organizasyonu içinde karşılaşır.</p>
            </div>
            <div class="timeline-step">
                <div class="timeline-num">04</div>
                <h3>Scout & Medya</h3>
                <p>Oyuncular scout ekipleri, medya ve sponsor markalar karşısında görünürlük elde eder.</p>
            </div>
            <div class="timeline-step">
                <div class="timeline-num">05</div>
                <h3>JLC Şampiyonu</h3>
                <p>Final maçları sonunda Junior League Cup şampiyonu belirlenir.</p>
            </div>
        </div>
    </div>
</section>

<section id="harita">
    <div class="container map-section">
        <div class="content-text">
            <span class="section-label">Bölgesel Seçmeler</span>
            <h2>Türkiye'nin Yetenekleri Antalya'da Buluşuyor</h2>
            <p>
                Bölgesel seçmeler, Junior League Cup yolculuğunun ilk adımıdır. Her bölgede başarılı olan takımlar
                Antalya final organizasyonuna katılmaya hak kazanır.
            </p>
            <a asp-action="BolgeselSecmeler" class="btn btn-primary" style="margin-top:1.25rem;">Şehirleri İncele</a>
        </div>
        <div class="map-visual" aria-hidden="true">
            <partial name="_TurkeyMap" />
        </div>
    </div>
</section>

<section class="section-muted" id="antalya">
    <div class="container content-grid">
        <div class="content-image" style="background-image: url('https://images.unsplash.com/photo-1459865264687-595d652de67e?w=900&q=80');" role="img" aria-label="Antalya final organizasyonu"></div>
        <div class="content-text">
            <span class="section-label">Antalya Finali</span>
            <h2>Büyük Final Antalya'da</h2>
            <p>
                Antalya, Junior League Cup'ın ana sahnesidir. Bölgesel seçmelerden gelen takımlar profesyonel futbol organizasyonu
                atmosferinde karşılaşır. Maçlar, scout değerlendirmeleri, medya çekimleri, ödül törenleri ve aile etkinlikleri bir arada yaşanır.
            </p>
            <ul class="check-list">
                <li>Profesyonel sahalar ve otel organizasyonu</li>
                <li>Grup, eleme ve final maçları</li>
                <li>Scout izleme alanı ve medya röportajları</li>
                <li>Kupa töreni ve aile etkinlikleri</li>
            </ul>
            <a asp-action="AntalyaFinali" class="btn btn-primary" style="margin-top:1.25rem;">Final Deneyimini Keşfet</a>
        </div>
    </div>
</section>

<section id="scout">
    <div class="container content-grid reverse">
        <div class="content-image" style="background-image: url('https://images.unsplash.com/photo-1522778119026-d647f0596c20?w=900&q=80');" role="img" aria-label="Scout değerlendirme"></div>
        <div class="content-text">
            <span class="section-label">Scout Sistemi</span>
            <h2>Genç Yetenekler İçin Görünürlük Alanı</h2>
            <p>
                Junior League Cup, oyuncuların gözlemlendiği ve değerlendirildiği bir ortam oluşturmayı hedefler.
                Scout ekipleri ve futbol profesyonelleri gelişim potansiyelini inceleme fırsatı bulur.
            </p>
            <div class="notice">
                Scout sistemi kesin transfer vaadi değildir; görünürlük ve değerlendirme fırsatı sunar.
            </div>
            <a href="#efsane-bulusma" class="btn btn-outline-dark" style="margin-right:0.75rem;">Efsane Buluşma Programı</a>
            <a asp-action="ScoutSistemi" class="btn btn-primary">Scout Sistemini İncele</a>
        </div>
    </div>
</section>

<section class="section-muted" id="efsane-bulusma">
    <div class="container content-grid">
        <div class="content-image content-image--legend" style="background-image: url('@Url.Content("~/images/ronaldinho.png")');" role="img" aria-label="Ronaldinho — efsane buluşma"></div>
        <div class="content-text">
            <span class="section-label">Görünürlük Alanı</span>
            <h2>Efsane Buluşma</h2>
            <p>
                Antalya finalinde, organizasyon takvimine göre belirlenen konuk futbolcularla kısa tanışma ve
                deneyim paylaşımı oturumları düzenlenir. Genç oyuncular ilham alır; kulüpler ve veliler programa dahil olabilir.
            </p>
            <ul class="check-list">
                <li>Tanışma ve motivasyon buluşmaları</li>
                <li>Kariyer hikâyelerini dinleme fırsatı</li>
            </ul>
            <div class="notice">
                Transfer veya kulüp taahhüdü içermez. Konuk isimleri ve program takvime göre duyurulur.
            </div>
            <a asp-action="AntalyaFinali" class="btn btn-primary" style="margin-top:1.25rem;">Antalya Finali</a>
        </div>
    </div>
</section>

<section class="section-muted" id="veli">
    <div class="container">
        <div class="section-header">
            <span class="section-label">Veli & Oyuncu</span>
            <h2>Çocuğunuz İçin Sadece Bir Turnuva Değil</h2>
            <p>Profesyonel saha atmosferi, medya içerikleri ve aile odaklı organizasyon deneyimi.</p>
        </div>
        <div class="package-grid">
            <div class="package-card">
                <h3>Standart Deneyim</h3>
                <p class="package-desc">Organizasyon katılımı ve temel maç programı.</p>
                <ul>
                    <li>Organizasyon katılımı</li>
                    <li>Maç programı ve takım fikstürü</li>
                    <li>Temel medya görünürlüğü</li>
                </ul>
            </div>
            <div class="package-card featured">
                <h3>Premium Oyuncu</h3>
                <p class="package-desc">Gelişmiş medya ve oyuncu kartı deneyimi.</p>
                <ul>
                    <li>Profesyonel fotoğraf çekimi</li>
                    <li>Kişisel oyuncu kartı</li>
                    <li>Kısa video içerik</li>
                    <li>Performans raporu</li>
                </ul>
            </div>
            <div class="package-card">
                <h3>Elite Scout</h3>
                <p class="package-desc">Detaylı profil ve scout değerlendirme alanı.</p>
                <ul>
                    <li>Detaylı oyuncu profili</li>
                    <li>Scout değerlendirme raporu</li>
                    <li>Özel medya içeriği</li>
                    <li>Röportaj / tanıtım alanı</li>
                </ul>
            </div>
        </div>
        <p style="text-align:center;margin-top:2rem;color:var(--text-muted);font-size:0.9rem;">
            Paket detayları ve fiyatlandırma yönetim panelinden güncellenecektir.
            <a asp-action="VeliOyuncuDeneyimi" style="color:var(--accent);font-weight:600;"> Tüm paketleri görüntüle →</a>
        </p>
    </div>
</section>

<section id="sponsor">
    <div class="container">
        <div class="section-header">
            <span class="section-label">Sponsorluk</span>
            <h2>Geleceğin Futbol Hikâyesinde Markanıza Yer Açın</h2>
            <p>Çocuk futbolu, aile deneyimi, medya görünürlüğü ve spor turizmini bir araya getiren güçlü sponsorluk platformu.</p>
        </div>
        <div class="sponsor-grid">
            <div class="sponsor-tier"><h3>Ana Sponsor</h3><ul><li>Logo ve web görünürlüğü</li><li>Organizasyon alanı</li><li>Medya içerikleri</li></ul></div>
            <div class="sponsor-tier"><h3>Bölgesel Sponsor</h3><ul><li>Şehir bazlı aktivasyon</li><li>Sosyal medya</li><li>Saha görünürlüğü</li></ul></div>
            <div class="sponsor-tier"><h3>Forma Sponsoru</h3><ul><li>Takım forma alanı</li><li>Fotoğraf ve video</li><li>Marka aktivasyonu</li></ul></div>
            <div class="sponsor-tier"><h3>Medya Sponsoru</h3><ul><li>İçerik sponsorluğu</li><li>Röportaj alanları</li><li>Dijital yayın</li></ul></div>
        </div>
        <div style="text-align:center;margin-top:2.5rem;">
            <a asp-action="Sponsorluk" class="btn btn-primary">Sponsorluk Dosyası Talep Et</a>
        </div>
    </div>
</section>

<section class="section-muted" id="medya">
    <div class="container">
        <div class="section-header">
            <span class="section-label">Medya</span>
            <h2>Road to Antalya İçerikleri</h2>
            <p>Haberler, röportajlar, fotoğraf ve video galerileri — yaşayan bir medya platformu.</p>
        </div>
        @await Html.PartialAsync("_NewsGrid", Model)
        </div>
        <div style="text-align:center;margin-top:2rem;">
            <a asp-action="Medya" class="btn btn-outline-dark">Tüm Medya İçerikleri</a>
        </div>
    </div>
</section>

<section id="oteller">
    <div class="container">
        <div class="section-header">
            <span class="section-label">Konaklama</span>
            <h2>Antalya'da Futbol ve Tatil Deneyimi</h2>
            <p>JLC Antalya final organizasyonu, futbol heyecanını Antalya'nın turizm gücüyle birleştirir.</p>
        </div>
        <div class="hotel-grid">
            <div class="hotel-card"><h3>Kremlin Palace</h3><p class="region">Kundu</p><p>Partner otel — konaklama ve transfer paketleri.</p></div>
            <div class="hotel-card"><h3>Limak Lara</h3><p class="region">Lara</p><p>Organizasyon konaklama partneri.</p></div>
            <div class="hotel-card"><h3>Fame Lara</h3><p class="region">Lara</p><p>Aile ve takım konaklama seçeneği.</p></div>
            
        </div>
        <div style="text-align:center;margin-top:2rem;">
            <a asp-action="Oteller" class="btn btn-outline-dark">Tüm Oteller</a>
        </div>
    </div>
</section>

<section class="section-muted">
    <div class="container">
        <div class="cta-banner">
            <div class="cta-bg" aria-hidden="true"></div>
            <div class="cta-overlay" aria-hidden="true"></div>
            <div class="cta-content">
                <h2>FROM LOCAL DREAMS TO THE BIG STAGE</h2>
                <p>Futbol okulunuz veya kulübünüz Junior League Cup yolculuğuna katılsın. Bölgesel seçmeler için ön kayıt oluşturun.</p>
                <a asp-action="TakimBasvurusu" class="btn btn-gold">Takım Başvurusu Yap</a>
                <a asp-action="Iletisim" class="btn btn-outline">Bize Ulaşın</a>
            </div>
        </div>
    </div>
</section>
