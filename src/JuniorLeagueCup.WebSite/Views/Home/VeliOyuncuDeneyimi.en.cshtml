@{
    ViewData["Title"] = "Parent & Player Experience";
    ViewData["Description"] = "Junior League Cup parent and player experience packages — professional pitches, media content, and scout visibility.";
}

<section class="page-hero">
    <div class="container">
        <h1>PARENT & PLAYER EXPERIENCE</h1>
        <p class="lead">More than a tournament for your child — an unforgettable football experience.</p>
        <p class="breadcrumb"><a asp-action="Index">Home</a> / Parent & Player Experience</p>
    </div>
</section>

<section class="content-section">
    <div class="container">
        <div class="features-grid" style="margin-bottom:3rem;">
            <div class="feature-box"><div class="feature-icon">🏟</div><h3>Professional Pitch Atmosphere</h3><p>Match experience at organization standards.</p></div>
            <div class="feature-box"><div class="feature-icon">📸</div><h3>Photo & Video</h3><p>Player shoots and media content.</p></div>
            <div class="feature-box"><div class="feature-icon">🪪</div><h3>Personal Player Card</h3><p>Digital and printed player profile.</p></div>
            <div class="feature-box"><div class="feature-icon">📊</div><h3>Performance Evaluation</h3><p>Development-focused reporting options.</p></div>
            <div class="feature-box"><div class="feature-icon">👁</div><h3>Scout Visibility</h3><p>Observation and evaluation opportunity.</p></div>
            <div class="feature-box"><div class="feature-icon">🏨</div><h3>Family Accommodation</h3><p>Organization and event experience in Antalya.</p></div>
        </div>
        <div class="package-grid">
            <div class="package-card">
                <h3>Standard Experience Package</h3>
                <p class="package-desc">Core organization participation.</p>
                <ul>
                    <li>Organization participation</li>
                    <li>Match program</li>
                    <li>Team fixtures</li>
                    <li>Basic media visibility</li>
                </ul>
            </div>
            <div class="package-card featured">
                <h3>Premium Player Package</h3>
                <p class="package-desc">Enhanced media and profile.</p>
                <ul>
                    <li>Professional photo shoot</li>
                    <li>Player card</li>
                    <li>Short video content</li>
                    <li>Performance report</li>
                </ul>
            </div>
            <div class="package-card">
                <h3>Elite Scout Package</h3>
                <p class="package-desc">Detailed profile and scout area.</p>
                <ul>
                    <li>Detailed player profile</li>
                    <li>Scout evaluation report</li>
                    <li>Exclusive media content</li>
                    <li>Interview / showcase area</li>
                </ul>
            </div>
        </div>
        <p style="text-align:center;margin-top:2rem;color:var(--text-muted);">Pricing will be updated from the management panel.</p>
    </div>
</section>
