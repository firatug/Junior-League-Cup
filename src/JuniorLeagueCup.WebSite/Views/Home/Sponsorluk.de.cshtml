@model JuniorLeagueCup.WebSite.Models.SponsorlukFormModel
@{
    ViewData["Title"] = "Sponsoring";
    ViewData["Description"] = "Junior League Cup Sponsoring-Möglichkeiten — Titelsponsor, Regionalsponsor, Medien- und Trikotsponsoring.";
}

<section class="page-hero">
    <div class="container">
        <h1>SPONSORING</h1>
        <p class="lead">Platzieren Sie Ihre Marke in der Geschichte der Zukunft des Fußballs.</p>
        <p class="breadcrumb"><a asp-action="Index">Startseite</a> / Sponsoring</p>
    </div>
</section>

<section class="content-section">
    <div class="container">
        <p style="max-width:720px;margin:0 auto 2.5rem;text-align:center;color:var(--text-muted);">
            Die Junior League Cup ist eine starke Sponsoring-Plattform, die Jugendfußball, Familienerlebnis,
            mediale Sichtbarkeit, Sporttourismus und gesellschaftlichen Impact vereint.
        </p>
        <div class="sponsor-grid">
            @foreach (var tier in new[] { "Titelsponsor", "Regionalsponsor", "Trikotsponsor", "Platzsponsor", "Scout-Erlebnis-Sponsor", "Mediensponsor", "MVP-Award-Sponsor", "Familien-Event-Sponsor" })
            {
                <div class="sponsor-tier">
                    <h3>@tier</h3>
                    <ul>
                        <li>Logo-Sichtbarkeit</li>
                        <li>Sichtbarkeit in sozialen Medien</li>
                        <li>Website-Sichtbarkeit</li>
                        <li>Sichtbarkeit vor Ort beim Event</li>
                        <li>News und Medieninhalte</li>
                        <li>Individuelle Markenaktivierung</li>
                    </ul>
                </div>
            }
        </div>
    </div>
</section>

<section class="content-section section-muted">
    <div class="container">
        <div class="section-header">
            <h2>Sponsoring-Dossier anfordern</h2>
        </div>
        <form class="apply-form" asp-action="SponsorlukPost" method="post" style="max-width:720px;margin:0 auto;">
            <div asp-validation-summary="All" class="admin-alert admin-alert-error" style="margin-bottom:1rem;"></div>
            <div class="form-row">
                <div class="form-group">
                    <label asp-for="Company">Firmenname</label>
                    <input asp-for="Company" />
                    <span asp-validation-for="Company" class="admin-field-error"></span>
                </div>
                <div class="form-group">
                    <label asp-for="Contact">Ansprechpartner</label>
                    <input asp-for="Contact" />
                    <span asp-validation-for="Contact" class="admin-field-error"></span>
                </div>
            </div>
            <div class="form-row">
                <div class="form-group">
                    <label asp-for="Phone">Telefon</label>
                    <input asp-for="Phone" type="tel" />
                    <span asp-validation-for="Phone" class="admin-field-error"></span>
                </div>
                <div class="form-group">
                    <label asp-for="Email">E-Mail</label>
                    <input asp-for="Email" type="email" />
                    <span asp-validation-for="Email" class="admin-field-error"></span>
                </div>
            </div>
            <div class="form-group">
                <label asp-for="SponsorType">Interessierte Sponsoring-Art</label>
                <select asp-for="SponsorType">
                    <option>Titelsponsor</option>
                    <option>Regionalsponsor</option>
                    <option>Trikotsponsor</option>
                    <option>Mediensponsor</option>
                    <option>Andere</option>
                </select>
            </div>
            <div class="form-group">
                <label asp-for="Message">Nachricht</label>
                <textarea asp-for="Message" rows="4"></textarea>
            </div>
            <button type="submit" class="btn btn-primary">Anfrage absenden</button>
        </form>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
