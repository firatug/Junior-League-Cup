@model JuniorLeagueCup.WebSite.Models.NewsArticle
@{
    ViewData["Title"] = Model.Title;
    ViewData["Description"] = Model.Summary;
    var image = NewsImagePaths.Resolve(Model.ImageUrl);
}

<section class="page-hero">
    <div class="container">
        <span class="media-tag" style="display:inline-block;margin-bottom:0.75rem;">@Model.Category</span>
        <h1>@Model.Title</h1>
        <p class="lead">@Model.Summary</p>
        <p class="breadcrumb">
            <a asp-action="Index">Ana Sayfa</a> /
            <a asp-action="Medya">Medya</a> /
            @Model.Title
        </p>
        <p style="margin-top:0.75rem;color:var(--text-muted);font-size:0.9rem;">
            @Model.PublishedAt.ToLocalTime().ToString("dd MMMM yyyy", new System.Globalization.CultureInfo("tr-TR"))
        </p>
    </div>
</section>

<section class="content-section">
    <div class="container" style="max-width:800px;">
        <div style="height:320px;border-radius:var(--radius-lg);background-size:cover;background-position:center;margin-bottom:2rem;background-image:url('@image');"></div>
        <div class="legal-content" style="line-height:1.8;color:var(--text);">
            @foreach (var paragraph in Model.Content.Split('\n', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries))
            {
                <p style="margin-bottom:1.25rem;">@paragraph</p>
            }
        </div>
        <div style="margin-top:2.5rem;">
            <a asp-action="Medya" class="btn btn-outline-dark">← Tüm Medya İçerikleri</a>
        </div>
    </div>
</section>
