@model JuniorLeagueCup.WebSite.Models.TakimBasvurusuFormModel
@{
    ViewData["Title"] = "Team- & Vereinsbewerbung";
    ViewData["Description"] = "Junior League Cup Teambewerbungsformular — Voranmeldung für regionale Auswahl von Fußballschulen und Vereinen.";
}

<section class="page-hero">
    <div class="container">
        <h1>TEAMBEWERBUNG</h1>
        <p class="lead">Fußballschulen und Vereine können das Bewerbungsformular ausfüllen, um sich für die regionale Auswahl voranzumelden.</p>
        <p class="breadcrumb"><a asp-action="Index">Startseite</a> / Teambewerbung</p>
    </div>
</section>

<section class="content-section">
    <div class="container">
        <form class="apply-form" asp-action="TakimBasvurusuPost" method="post">
            <div asp-validation-summary="All" class="admin-alert admin-alert-error" style="margin-bottom:1rem;"></div>
            <div class="form-row">
                <div class="form-group">
                    <label asp-for="ClubName">Vereins- / Fußballschulname</label>
                    <input asp-for="ClubName" />
                    <span asp-validation-for="ClubName" class="admin-field-error"></span>
                </div>
                <div class="form-group">
                    <label asp-for="ContactName">Name des bevollmächtigten Ansprechpartners</label>
                    <input asp-for="ContactName" />
                    <span asp-validation-for="ContactName" class="admin-field-error"></span>
                </div>
            </div>
            <div class="form-row">
                <div class="form-group">
                    <label asp-for="Phone">Telefon</label>
                    <input asp-for="Phone" type="tel" />
                    <span asp-validation-for="Phone" class="admin-field-error"></span>
                </div>
                <div class="form-group">
                    <label asp-for="Email">E-Mail</label>
                    <input asp-for="Email" type="email" />
                    <span asp-validation-for="Email" class="admin-field-error"></span>
                </div>
            </div>
            <div class="form-row">
                <div class="form-group">
                    <label asp-for="City">Stadt</label>
                    <select asp-for="City">
                        <option value="">Auswählen</option>
                        <option>İstanbul</option>
                        <option>Ankara</option>
                        <option>İzmir</option>
                        <option>Bursa</option>
                        <option>Adana</option>
                        <option>Antalya</option>
                        <option>Andere</option>
                    </select>
                    <span asp-validation-for="City" class="admin-field-error"></span>
                </div>
                <div class="form-group">
                    <label asp-for="AgeGroup">Alterskategorie des Teams</label>
                    <select asp-for="AgeGroup">
                        <option value="">Auswählen</option>
                        <option>7 Jahre</option>
                        <option>8 Jahre</option>
                    </select>
                    <span asp-validation-for="AgeGroup" class="admin-field-error"></span>
                </div>
            </div>
            <div class="form-group">
                <label asp-for="PlayerCount">Anzahl der Spieler</label>
                <input asp-for="PlayerCount" min="8" max="20" />
            </div>
            <div class="form-group">
                <label asp-for="PastEvents">Bisherige Turniere / Veranstaltungen</label>
                <textarea asp-for="PastEvents" rows="3"></textarea>
            </div>
            <div class="form-group">
                <label asp-for="Notes">Anmerkungen</label>
                <textarea asp-for="Notes" rows="3"></textarea>
            </div>
            <div class="form-check">
                <input asp-for="Kvkk" />
                <label asp-for="Kvkk">Ich habe die <a asp-action="Kvkk" target="_blank">Datenschutzerklärung (KVKK)</a> gelesen und stimme der Verarbeitung meiner personenbezogenen Daten zu.</label>
                <span asp-validation-for="Kvkk" class="admin-field-error"></span>
            </div>
            <div class="form-check">
                <input asp-for="Cerez" />
                <label asp-for="Cerez">Ich habe die <a asp-action="CerezPolitikasi" target="_blank">Cookie-Richtlinie</a> gelesen und akzeptiere sie.</label>
                <span asp-validation-for="Cerez" class="admin-field-error"></span>
            </div>
            <button type="submit" class="btn btn-primary" style="margin-top:1rem;">Bewerbung absenden</button>
        </form>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
