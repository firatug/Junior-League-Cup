@model JuniorLeagueCup.WebSite.Models.AdminLoginViewModel
@{
    ViewData["Title"] = "Admin Giriş";
    Layout = "_AdminLayout";
}

<div class="admin-card admin-login-card">
    <h1>Yönetim Paneli</h1>
    <p class="admin-subtitle">Haber yönetimi için giriş yapın.</p>

    <form asp-action="Login" method="post">
        @Html.AntiForgeryToken()
        <input type="hidden" name="returnUrl" value="@ViewData["ReturnUrl"]" />
        <div asp-validation-summary="ModelOnly" class="admin-alert admin-alert-error"></div>

        <div class="admin-form-group">
            <label asp-for="Username"></label>
            <input asp-for="Username" class="admin-input" autocomplete="username" />
            <span asp-validation-for="Username" class="admin-field-error"></span>
        </div>

        <div class="admin-form-group">
            <label asp-for="Password"></label>
            <input asp-for="Password" class="admin-input" autocomplete="current-password" />
            <span asp-validation-for="Password" class="admin-field-error"></span>
        </div>

        <button type="submit" class="btn btn-primary admin-btn-full">Giriş Yap</button>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
